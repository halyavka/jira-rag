# Secrets shared between jira-rag and mirelia-agent docker-compose stacks.
# Copy to a location readable by both composes, e.g. /opt/rag/shared.env.
# Reference via `env_file: ./shared.env` in each compose.

# ── Jira Cloud ───────────────────────────────────────────────────────────────
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# ── Supabase (same DB, different schemas — api.* for mirelia, jira.* for jira-rag) ──
SUPABASE_DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Shared Qdrant (set by compose automatically inside rag-shared network) ──
# QDRANT_HOST is set per-service in compose; no need here.
